PORT=5000
MONGODB_URI=mongodb://localhost:27017/fudo
JWT_SECRET=your_super_secret_jwt_key_here_change_this
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@fudo.club
ADMIN_PASSWORD=FudoAdmin@2024

# Email OTP via Nodemailer (Gmail example — use an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM="FUDO Lifting Club <your_gmail@gmail.com>"

# WhatsApp Business API (fill when ready)
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# Cloudinary — required for file uploads on Vercel (get from cloudinary.com/console)
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Cron job security secret — Vercel sends this as "Authorization: Bearer <secret>"
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here

CLIENT_URL=http://localhost:5173
NODE_ENV=development
